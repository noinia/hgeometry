--------------------------------------------------------------------------------
-- * HGeometry-quickcheck

library quickcheck
    import: all-setup, hgeometry-setup, all-quickcheck-setup, quickcheck-setup
    visibility: public
    hs-source-dirs: src-quickcheck
    exposed-modules:
      HGeometry.Instances
      HGeometry.Polygon.Monotone.Instances
      HGeometry.Polygon.Convex.Instances
      HGeometry.PlaneGraph.Instances
    other-modules:
      Paths_hgeometry
    autogen-modules:
      Paths_hgeometry
    build-depends:
         hgeometry
       -- , cereal   >= 0.5    && < 1

library ply-writer
    import: all-setup
    visibility: public
    hs-source-dirs: ply/src
    exposed-modules:
      PLY.Writer
    build-depends:
         hgeometry-point
       , hgeometry-kernel
       , colour                  >= 2.3.6         && < 3


