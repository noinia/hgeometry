-- ** HGeometry Benchmarks

common bench-setup
  build-depends:
      tasty-bench           >= 0.3  && < 1
    , hgeometry
    , deepseq-generics      >= 0.2  && < 1
    , hashable              >= 1.4  && < 2
    , hgeometry-vector:numtypes

benchmark benchmarks
  import: all-setup, hgeometry-setup, bench-setup
  hs-source-dirs: bench
  main-is:        Benchmarks.hs
  type: exitcode-stdio-1.0
  other-modules:
    ConvexHull.Bench
    ConvexHull.GrahamBench
    ConvexHull.GrahamV2
    ConvexHull.GrahamInt
    ConvexHull.GrahamFastest
    -- ConvexHull.GrahamClassy
    Util

benchmark lowerEnv
  import:         all-setup, hgeometry-setup, bench-setup
  hs-source-dirs: bench
  main-is:        LowerEnvBench.hs
  type:           exitcode-stdio-1.0
  -- ghc-options:
  --   -prof
  --   -fprof-late-inline
  --   -fprof-auto
  --   -rtsopts "-with-rtsopts=-p"
  other-modules:

benchmark batchPointLocation
  import:         all-setup, hgeometry-setup, bench-setup
  hs-source-dirs: bench
  main-is:        BatchPointLocationBench.hs
  type:           exitcode-stdio-1.0
  mixins:
      hgeometry-vector:numtypes (IntervalReal as R)
  build-depends:
         hgeometry-ipe
       , time                    >= 1.14 && < 1.16
