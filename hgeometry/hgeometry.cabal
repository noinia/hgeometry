-- ** HGeometry

common test-fractional
  build-tool-depends: hspec-discover:hspec-discover
  build-depends:
      hgeometry:quickcheck
    , hgeometry-polygon:quickcheck
    , hgeometry-vector:numtypes
  hs-source-dirs: test/fractional
  other-modules:
      Spec
      ConvexHull.ConvexHullSpec
      ConvexHull.MelkmanSpec
      ConvexHull.R3Spec
      ClosestPair.ClosestPairSpec
      LowerEnvelope.RegionsSpec
      Polygon.Convex.ConvexSpec
      Polygon.Convex.UnboundedSpec
      Polygon.TriangulateSpec
      Polygon.Triangulation.MakeMonotoneSpec
      PolyLine.Simplification.ImaiIriSpec
      PolyLine.Frechet.DiscreteSpec
      VerticalRayShootingSpec
      LineSegment.BentheyOttmanNeighbourSpec
      Graphics.CameraSpec
      Plane.LowerEnvSpec

test-suite hspec-rational
  import:           all-setup, hgeometry-setup, all-quickcheck-setup,
                    quickcheck-setup, test-fractional
  type:             exitcode-stdio-1.0
  main-is:          Main.hs
  mixins:
      hgeometry-vector:numtypes (Rational as R)

test-suite hspec-intervalreal
  import:           all-setup, hgeometry-setup, all-quickcheck-setup,
                    quickcheck-setup, test-fractional
  type:             exitcode-stdio-1.0
  main-is:          Main.hs
  mixins:
      hgeometry-vector:numtypes (IntervalReal as R)

